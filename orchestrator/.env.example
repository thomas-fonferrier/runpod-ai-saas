# RunPod credentials
RUNPOD_API_KEY=your_runpod_api_key_here

# Endpoint IDs — copy from RunPod console after creating each endpoint
FLUX_ENDPOINT_ID=your_flux_endpoint_id
LTXVIDEO_ENDPOINT_ID=your_ltxvideo_endpoint_id
XTTS_ENDPOINT_ID=your_xtts_endpoint_id

# Job polling settings
POLL_INTERVAL_SECONDS=2
MAX_WAIT_SECONDS=300
